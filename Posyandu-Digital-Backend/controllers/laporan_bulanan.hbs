<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: sans-serif; font-size: 12px; }
        .header { text-align: center; margin-bottom: 20px; border-bottom: 2px solid black; padding-bottom: 10px; }
        h2 { margin: 0; text-transform: uppercase; }
        p { margin: 2px 0; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { border: 1px solid #333; padding: 6px; text-align: left; }
        th { background-color: #f2f2f2; text-align: center; font-weight: bold; }
        .footer { margin-top: 30px; text-align: right; }
        .ttd { margin-top: 60px; margin-right: 30px; }
        .status-buruk { color: red; font-weight: bold; }
    </style>
</head>
<body>
    <div class="header">
        <h2>LAPORAN HASIL PENIMBANGAN BALITA</h2>
        <p>POSYANDU {{nama_posyandu}} - DESA {{nama_desa}}</p>
        <p>PERIODE: {{periode}}</p>
    </div>

    <table>
        <thead>
            <tr>
                <th style="width: 5%">No</th>
                <th style="width: 22%">Nama Balita</th>
                <th style="width: 5%">JK</th>
                <th style="width: 12%">Tgl Ukur</th>
                <th style="width: 10%">Umur</th>
                <th style="width: 12%">Berat</th>
                <th style="width: 17%">Status Gizi (BB/U)</th>
                <th style="width: 17%">Catatan</th>
            </tr>
        </thead>
        <tbody>
            {{#each data}}
            <tr>
                <td style="text-align: center;">{{no}}</td>
                <td>{{nama_anak}}</td>
                <td style="text-align: center;">{{jk}}</td>
                <td style="text-align: center;">{{tgl_ukur}}</td>
                <td style="text-align: center;">{{umur}}</td>
                <td style="text-align: center;">{{bb}}</td>
                <td>{{status_gizi}}</td>
                <td>{{catatan}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div class="footer">
        <p>Subang, {{tanggal_cetak}}</p>
        <p>Mengetahui,</p>
        <p>Ketua Kader</p>
        <div class="ttd">( ....................................... )</div>
    </div>
</body>
</html>